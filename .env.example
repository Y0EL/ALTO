# ============================================
# Backend env - copy relevant values to backend/.env
# ============================================

# Runtime
NODE_ENV=development
PORT=3000

# CORS. Comma-separated browser origins allowed to send credentialed requests.
# Examples:
#   local:   http://localhost:5173
#   staging: https://alto-staging-web.netlify.app
#   prod:    https://alto.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173

# Upload safety limit. Keep this realistic while uploads are buffered in API memory.
MAX_UPLOAD_MB=100

# Production upload mode. Uncomment and fill for Cloudflare R2, AWS S3,
# or another S3-compatible store. Without this, local fallback uploads
# through the API process.
# STORAGE_PROVIDER=s3
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=alto-staging-uploads
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_FORCE_PATH_STYLE=true
# S3_SIGNED_URL_TTL_SEC=900

# Worker
WORKER_POLL_MS=5000

# Login rate limit
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_SEC=900

# Postgres
DATABASE_URL=postgres://user:pass@ep-xxx.region.neon.tech/dbname?sslmode=require

# Upstash Redis REST API
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxx

# Active transcription and summary providers
DEEPGRAM_API_KEY=your-deepgram-key
OPENAI_API_KEY=sk-...

# Initial admin seed.
# In staging/production, the seed script refuses weak defaults like "123".
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me-min-8-chars

# Optional legacy/experimental Gemini helper config.
# The active upload route currently uses Deepgram, not Gemini.
# GEMINI_API_KEY=AIzaSy...your-key-here
# GEMINI_MODEL=gemini-2.5-flash

# ============================================
# Frontend env - copy relevant values to frontend/.env
# ============================================

# Only VITE_ prefixed vars are exposed to the browser.
VITE_API_URL=http://localhost:3000
VITE_MAX_UPLOAD_MB=100
