# ============================================
# Backend (Fly.io) — copy to backend/.env
# ============================================

# Google Gemini API
GEMINI_API_KEY=AIzaSy...your-key-here

# Neon Postgres (https://neon.tech)
DATABASE_URL=postgres://user:pass@ep-xxx.region.neon.tech/dbname?sslmode=require

# Upstash Redis (https://upstash.com)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxx

# Default admin seed
DEFAULT_ADMIN_USERNAME=yoel
DEFAULT_ADMIN_PASSWORD=123

# CORS: comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.netlify.app

# Optional: override Gemini model (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Server
PORT=3000
NODE_ENV=development

# ============================================
# Frontend (Netlify) — copy to frontend/.env
# ============================================
# Only VITE_ prefixed vars are exposed to client.
VITE_API_URL=http://localhost:3000
